{
  "info": {
    "name": "Volt Forge - Company (User)",
    "description": "Company-side self-service endpoints: register, view own profile/wallet, apply for a plan, and manage passports.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api" },
    { "key": "companyId", "value": "1" },
    { "key": "planId", "value": "1" },
    { "key": "applicationId", "value": "1" },
    { "key": "walletId", "value": "1" },
    { "key": "passportId", "value": "1" },
    { "key": "recordId", "value": "1" },
    { "key": "passportNumber", "value": "BATT-0001" },
    { "key": "newResponsibleCompanyId", "value": "2" }
  ],
  "item": [
    {
      "name": "Company Profile",
      "item": [
        {
          "name": "Register Company",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/companies",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Acme Corp\",\n  \"address\": \"123 Main St, Springfield\"\n}"
            }
          }
        },
        { "name": "Get Company Profile", "request": { "method": "GET", "url": "{{baseUrl}}/companies/{{companyId}}" } },
        {
          "name": "Update Company Profile",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/companies/{{companyId}}",
            "body": { "mode": "raw", "raw": "{\n  \"address\": \"456 New Address Ave\"\n}" }
          }
        }
      ]
    },
    {
      "name": "Plans",
      "item": [
        { "name": "List Active Plans", "request": { "method": "GET", "url": "{{baseUrl}}/plans?active=true" } },
        { "name": "Get Plan Details", "request": { "method": "GET", "url": "{{baseUrl}}/plans/{{planId}}" } }
      ]
    },
    {
      "name": "Company Applications",
      "item": [
        {
          "name": "Apply for a Plan",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/company-applications",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"company_id\": {{companyId}},\n  \"plan_id\": {{planId}}\n}"
            }
          }
        },
        { "name": "List My Applications", "request": { "method": "GET", "url": "{{baseUrl}}/company-applications/company/{{companyId}}" } },
        { "name": "Get Application Details", "request": { "method": "GET", "url": "{{baseUrl}}/company-applications/{{applicationId}}" } }
      ]
    },
    {
      "name": "Wallet",
      "item": [
        { "name": "Get My Wallet", "request": { "method": "GET", "url": "{{baseUrl}}/company-wallets/company/{{companyId}}" } },
        { "name": "List My Funding History", "request": { "method": "GET", "url": "{{baseUrl}}/wallet-funding-logs/company/{{companyId}}" } }
      ]
    },
    {
      "name": "Passports",
      "item": [
        {
          "name": "Create Passport (queues on-chain createPassport)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/passports",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"company_id\": {{companyId}},\n  \"passport_number\": \"{{passportNumber}}\",\n  \"passport_hash\": \"lot-2026-cell-chemistry-nmc811\"\n}"
            },
            "description": "Requires: company is_approved='yes', an active custodial wallet, an approved plan application, and remaining passport quota. Creates the passport + a pending passport_blockchain_records row, and queues a 'create_passport' job for the blockchain worker."
          }
        },
        { "name": "List My Passports", "request": { "method": "GET", "url": "{{baseUrl}}/passports/company/{{companyId}}" } },
        { "name": "Get Passport Details", "request": { "method": "GET", "url": "{{baseUrl}}/passports/{{passportId}}" } },
        { "name": "List Blockchain Records for My Passport", "request": { "method": "GET", "url": "{{baseUrl}}/passport-blockchain-records/passport/{{passportId}}" } },
        { "name": "List Blockchain Records for My Company", "request": { "method": "GET", "url": "{{baseUrl}}/passport-blockchain-records/company/{{companyId}}" } },
        {
          "name": "Sync Passport from Chain (Infura read)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/passport-blockchain-records/sync/{{passportNumber}}"
          },
          "description": "Reads the passport directly from the smart contract via Infura and reconciles the DB record with on-chain truth."
        },
        {
          "name": "Add Lifecycle Update (queues on-chain updatePassport)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/passport-blockchain-records/{{recordId}}/lifecycle",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"data\": { \"event\": \"state-of-health-check\", \"soh_percent\": 92, \"timestamp\": \"2026-07-16T00:00:00Z\" }\n}"
            },
            "description": "Hashes `data` to bytes32, bumps the passport's version, and queues an 'update_passport' job signed by the company's custodial wallet."
          }
        },
        {
          "name": "Transfer Responsibility (queues on-chain transferResponsibility)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/passport-blockchain-records/{{recordId}}/transfer",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"new_company_id\": {{newResponsibleCompanyId}}\n}"
            },
            "description": "Hands the passport off to another authorized company. Both companies must already have custodial wallets."
          }
        }
      ]
    }
  ]
}
