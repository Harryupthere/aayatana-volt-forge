PORT=5000
NODE_ENV=development

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=aayatana

# --- Blockchain / Web3 (Polygon Amoy testnet) ---
# Infura endpoint for Polygon Amoy. Get an API key at https://app.infura.io
INFURA_API_KEY=
POLYGON_AMOY_RPC_URL=https://polygon-amoy.infura.io/v3/YOUR_INFURA_API_KEY
CHAIN_ID=80002

# Deployed DigitalBatteryPassport contract
CONTRACT_ADDRESS=
CONTRACT_ABI_PATH=./src/contracts/VoltForgeOS.abi.json

# AES-256-GCM key (64 hex chars / 32 bytes) used to encrypt custodial wallet
# private keys before they are stored in admins.encrypted_pk / company_wallets.encrypted_pk.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WALLET_ENCRYPTION_KEY=

# Background worker that processes blockchain_transaction_queue
BLOCKCHAIN_WORKER_INTERVAL_MS=10000
BLOCKCHAIN_WORKER_MAX_RETRIES=3
